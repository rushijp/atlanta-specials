rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Phera: User profiles ───────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Phera: Weddings ────────────────────────────────────────────
    match /weddings/{weddingId} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      // Subcollections: events, guests, families, seating, photoGroups, bets
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/weddings/$(weddingId)).data.ownerId == request.auth.uid;
      }
    }

    // ─── Legacy: wedding photo queue ────────────────────────────────
    match /wedding/{docId} {
      allow read, write: if true;
    }

    // ─── Legacy: other collections ──────────────────────────────────
    match /submissions/{docId} {
      allow read: if false;
      allow create: if request.auth != null
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.restaurantName is string
        && request.resource.data.restaurantName.size() > 0
        && request.resource.data.restaurantName.size() <= 100
        && request.resource.data.deal is string
        && request.resource.data.deal.size() > 0
        && request.resource.data.deal.size() <= 500
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    match /ratings/{restaurantKey} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /bookmarks/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /auto_deals/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /reviews/{restaurantKey} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
